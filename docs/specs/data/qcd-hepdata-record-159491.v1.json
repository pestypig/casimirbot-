page=true"}]},{"data":{"csv":"https://www.hepdata.net/download/table/ins2931450/Figure 2 from Methods/csv","json":"https://www.hepdata.net/download/table/ins2931450/Figure 2 from Methods/json","root":"https://www.hepdata.net/download/table/ins2931450/Figure 2 from Methods/root","yaml":"https://www.hepdata.net/download/table/ins2931450/Figure 2 from Methods/yaml","yoda":"https://www.hepdata.net/download/table/ins2931450/Figure 2 from Methods/yoda","yoda.h5":"https://www.hepdata.net/download/table/ins2931450/Figure 2 from Methods/yoda.h5","yoda1":"https://www.hepdata.net/download/table/ins2931450/Figure 2 from Methods/yoda1"},"description":"Relative contribution to $\\Lambda\\bar{\\Lambda}$ hyperon pair feed-down from PYTHIA 8.2 event generator events, which are simulated through the STAR detector....","doi":"10.17182/hepdata.159491.v1/t6","id":1839025,"location":"Data from Figure 2 in Methods","messages":false,"name":"Figure 2 from Methods","processed_name":"Figure2fromMethods","resources":[{"description":"Image file","type":"png","url":"https://www.hepdata.net/record/resource/4007936?landing_page=true"},{"description":"Thumbnail image file","type":"png","url":"https://www.hepdata.net/record/resource/4007937?landing_page=true"}]}],"mode":"record","participant_count":3,"recid":159491,"record":{"abstract":"The vacuum is now understood to possess a rich and complex structure, characterized by fluctuating energy fields and a condensate of virtual quark-antiquark pairs. The spontaneous breaking of the approximate chiral symmetry, signaled by the nonvanishing quark condensate $\\langle q\\bar{q}\\rangle$, is dynamically generated through topologically nontrivial gauge configurations such as instantons. The precise mechanism linking the chiral symmetry breaking to the mass generation associated with quark confinement remains a profound open question in Quantum Chromodynamics (QCD) - the fundamental theory of strong interaction. High energy proton-proton collisions could liberate virtual quark-antiquark pairs from the vacuum that subsequently undergo confinement to form hadrons, whose properties could serve as probes into QCD confinement and the quark condensate. Here, we report evidence of spin correlations in $\u039b\\bar\u039b$ hyperon pairs inherited from spin-correlated strange quark-antiquark virtual pairs. Measurements by the STAR experiment at the Relativistic Heavy-Ion Collider (RHIC) at Brookhaven National Laboratory reveal a relative polarization signal of $(18 \\pm 4)\\%$ that links the virtual spin-correlated quark pairs from the QCD vacuum to their final-state hadron counterparts. Crucially, this correlation vanishes when the hyperon pairs are widely separated in angle, consistent with the decoherence of the quantum system. Our findings provide a new experimental paradigm for exploring the dynamics and interplay of quark confinement and entanglement.","access_urls":{"links":{"csv":"https://www.hepdata.net/download/submission/ins2931450/1/csv","json":"https://www.hepdata.net/download/submission/ins2931450/1/json","root":"https://www.hepdata.net/download/submission/ins2931450/1/root","yaml":"https://www.hepdata.net/download/submission/ins2931450/1/yaml","yoda":"https://www.hepdata.net/download/submission/ins2931450/1/yoda","yoda-h5":"https://www.hepdata.net/download/submission/ins2931450/1/yoda.h5"}},"analyses":[],"arxiv_id":"arXiv:2506.05499","collaborations":["STAR"],"control_number":"159491","creation_date":"2025-06-05","data_abstract":null,"data_keywords":{"cmenergies":[{"gte":200.0,"lte":200.0}],"observables":["Spin-spin correlation $P_\\mathrm{\\Lambda_1\\Lambda_2}$","$\\mathrm{d}N/\\mathrm{d}\\cos\\theta^\\star$","Relative feed-down cotribution."],"phrases":["spin-spin correlations","STAR","RHIC"],"reactions":["p+p $\\rightarrow$ $\\Lambda\\bar{\\Lambda}$ + X","p+p $\\rightarrow$ $\\Lambda\\Lambda$ + X","MC p+p $\\rightarrow$ $\\Lambda\\bar{\\Lambda}$ + X","p+p $\\rightarrow$ $K^0_\\mathrm{S}K^0_\\mathrm{S}$ + X","p+p $\\rightarrow$ $\\bar{\\Lambda}\\bar{\\Lambda}$ + X"]},"doc_type":"publication","doi":"10.1038/s41586-025-09920-0","first_author":{"affiliation":"Texas A-M","full_name":"Aboona, B.E."},"hepdata_doi":"10.17182/hepdata.159491.v1","id":159491,"inspire_id":"2931450","journal_info":"Nature 650 (2026) 65-71","keywords":[],"last_updated":"Sun, 08 Feb 2026 16:13:29 GMT","parent_child_join":{"name":"parent_publication"},"publication_date":"2026-02-27T00:00:00","recid":159491,"resources":[{"description":"arXiv","type":"html","url":"https://arxiv.org/abs/2506.05499"}],"subject_area":["hep-th","nucl-ex","hep-ex","nucl-th","hep-ph"],"summary_authors":[{"affiliation":"Texas A-M","full_name":"Aboona, B.E."},{"affiliation":"Prague, Tech. U.","full_name":"Adam, J."},{"affiliation":"AGH-UST, Cracow","full_name":"Adamczyk, L."},{"affiliation":"Panjab U., Chandigarh","full_name":"Aggarwal, I."},{"affiliation":"Panjab U., Chandigarh","full_name":"Aggarwal, M.M."},{"affiliation":"Calcutta, VECC","full_name":"Ahammed, Z."},{"affiliation":"Kent State U.","full_name":"Alshammri, A.K."},{"affiliation":"Brookhaven","full_name":"Aschenauer, E.C."},{"affiliation":"Fudan U.","full_name":"Aslam, S."},{"affiliation":"Abilene Christian U.","full_name":"Atchison, J."}],"title":"Measuring spin correlation between quarks during QCD confinement","type":["article"],"uuid":"d00f9061-1a21-4116-a3ca-cbe042ad83d1","version":1,"year":"2026"},"record_type":"publication","related_recids":[],"related_to_this_recids":[],"resources_with_doi":[],"reviewers_notified":true,"site_url":"https://www.hepdata.net","status":"finished","table_id_to_show":1839020,"table_name_to_show":"Figure 2 a)","version":1,"version_count":1,"watched":false}
