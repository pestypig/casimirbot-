{
  "version": "helix_ask_equation_benchmark/1",
  "description": "Coverage-first benchmark pack for equation anchor quality and mechanism explanation quality.",
  "cases": [
    {
      "id": "collapse_wave_equation_broad",
      "label": "collapse wave equation broad intent",
      "question": "explain equation of the collapse of the wave function?",
      "expect": {
        "primaryTopic": "collapse",
        "requiredSections": [
          "Primary Topic",
          "Primary Equation",
          "Mechanism Explanation"
        ],
        "requireConsensusFrame": true,
        "requiredMechanismPatterns": [
          "General-reference baseline",
          "Repo-grounded support",
          "Challenge status"
        ],
        "preferredEquationPatterns": [
          "psi|rho|collapse|measurement|born|state"
        ],
        "preferredSourcePaths": [
          "server/services/mixer/collapse.ts",
          "shared/dp-collapse.ts"
        ],
        "forbiddenEquationPatterns": [
          "\\bvolume\\s*=\\s*\\(4\\s*/\\s*3\\)"
        ],
        "minMechanismChars": 140,
        "passThreshold": 68
      }
